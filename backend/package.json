{
  "name": "trailpack-backend",
  "version": "1.0.0",
  "description": "Backend API for TrailPack - Smart Camping Trip Planner",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.450.0",
    "@aws-sdk/client-ses": "^3.450.0",
    "@aws-sdk/lib-dynamodb": "^3.450.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "openai": "^4.20.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "aws-sdk-client-mock": "^3.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/__tests__/setup.js"
    ]
  },
  "keywords": [
    "camping",
    "backpacking",
    "trip-planner",
    "checklist"
  ],
  "author": "Patel Hetvi",
  "license": "MIT"
}
