AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=TrailPack
JWT_SECRET=
PORT=3000
FRONTEND_URL=http://localhost:5500

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=

# Email/Notification Service (optional)
EMAIL_SERVICE_API_KEY=

# Google Gemini (used by aiService.generateGearSuggestions for
# POST /trips/:id/ai-items). Without this key the endpoint returns
# 201 with an empty `inserted` array.
GEMINI_API_KEY=

# OpenAI (optional — retained for legacy aiService methods that
# aren't wired into any active route today).
OPENAI_API_KEY=
