# TrailPack Environment Variables

# Figma MCP Server Configuration
# Get your token from: https://www.figma.com/settings/personal-access-tokens
FIGMA_ACCESS_TOKEN=your_figma_access_token_here

# MongoDB Connection (for local development)
MONGODB_URI=mongodb://localhost:27017/trailpack

# Server Port
PORT=3000

# Note: Replace 'your_figma_access_token_here' with your actual Figma token
# Instructions to get token:
# 1. Go to https://www.figma.com/settings/personal-access-tokens
# 2. Click "Create new token"
# 3. Name it "TrailPack MCP" (or any name)
# 4. Copy the token and paste it above
