# =============================================================================
# TrailPack Environment Variables
# Copy this file to `.env` and fill in values. `.env` is gitignored.
# =============================================================================

# ---- Core ----
# Port the Express server listens on.
PORT=3000

# Required in production. A missing JWT_SECRET will throw at boot when
# NODE_ENV=production. In dev/test a safe fallback is used.
JWT_SECRET=change-me-to-a-long-random-string

# Optional: set to "production" in your deploy environment.
NODE_ENV=development

# ---- CORS ----
# Comma-separated allowlist. Localhost is always allowed. Supports exact origins
# and "*." subdomain wildcards.
# Example: https://trailpack.com,*.netlify.app,https://staging.trailpack.com
CORS_ALLOWED_ORIGINS=

# ---- AWS / DynamoDB ----
# Used by the DynamoDB client and AWS SES.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Main single-table name (trips + items + collaborator rows).
DYNAMODB_TABLE_NAME=TrailPack-Trips

# Separate users table (keyed by userId, optional EmailIndex GSI).
DYNAMODB_USERS_TABLE=TrailPack-Users

# ---- Email (optional) ----
# If DISABLE_EMAIL=true or NODE_ENV=test, all emails are silent no-ops.
DISABLE_EMAIL=false
# Cron-based reminders are OFF unless this is exactly "true".
ENABLE_EMAIL_SCHEDULER=false

# Option A: AWS SES (preferred in production).
AWS_SES_REGION=us-east-1

# Option B: Gmail / SMTP for local dev.
EMAIL_USER=
EMAIL_PASS=

# Shown as the From address on outgoing mail.
EMAIL_FROM=noreply@trailpack.app

# Fully-qualified frontend URL used when building invite / reminder links.
FRONTEND_URL=http://localhost:8080

# ---- Weather (optional) ----
# Open-Meteo (used by /weather) needs no key. The legacy OpenWeather / Mapbox
# integrations in services/aiService.js use these when set.
WEATHER_API_KEY=
MAPBOX_TOKEN=

# ---- AI (optional) ----
# Enables the richer AI insights in services/aiService.js.
OPENAI_API_KEY=

# ---- Figma MCP Server (developer tooling only) ----
# https://www.figma.com/settings/personal-access-tokens
FIGMA_ACCESS_TOKEN=
